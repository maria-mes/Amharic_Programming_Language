Grammar

Rule 0     S' -> program
Rule 1     program -> statements
Rule 2     statements -> statements statement
Rule 3     statements -> statement
Rule 4     block -> LBRACE statements RBRACE
Rule 5     statement -> VAR ID ASSIGN expression
Rule 6     statement -> ID ASSIGN expression
Rule 7     statement -> PRINT LPAREN expression RPAREN
Rule 8     statement -> IF expression block
Rule 9     statement -> IF expression block ELSE block
Rule 10    statement -> WHILE expression block
Rule 11    statement -> FUNCTION ID LPAREN parameters RPAREN block
Rule 12    statement -> RETURN expression
Rule 13    parameters -> parameters COMMA ID
Rule 14    parameters -> ID
Rule 15    parameters -> <empty>
Rule 16    arguments -> arguments COMMA expression
Rule 17    arguments -> expression
Rule 18    arguments -> <empty>
Rule 19    expression -> ID LPAREN arguments RPAREN
Rule 20    expression -> expression PLUS expression
Rule 21    expression -> expression MINUS expression
Rule 22    expression -> expression TIMES expression
Rule 23    expression -> expression DIVIDE expression
Rule 24    expression -> expression LT expression
Rule 25    expression -> expression GT expression
Rule 26    expression -> expression LTE expression
Rule 27    expression -> expression GTE expression
Rule 28    expression -> expression EQUALS expression
Rule 29    expression -> NUMBER
Rule 30    expression -> STRING
Rule 31    expression -> ID
Rule 32    expression -> LPAREN expression RPAREN
Rule 33    empty -> <empty>

