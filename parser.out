ASSIGN               : 5 6
COMMA                : 13 16
DIVIDE               : 23
ELSE                 : 9
EQUALS               : 28
FUNCTION             : 11
GT                   : 25
GTE                  : 27
ID                   : 5 6 11 13 14 19 31
IF                   : 8 9
LBRACE               : 4
LPAREN               : 7 11 19 32
LT                   : 24
LTE                  : 26
MINUS                : 21
NUMBER               : 29
PLUS                 : 20
PRINT                : 7
RBRACE               : 4
RETURN               : 12
RPAREN               : 7 11 19 32
STRING               : 30
TIMES                : 22
VAR                  : 5
WHILE                : 10
error                : 

